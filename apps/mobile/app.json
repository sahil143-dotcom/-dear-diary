{
  "expo": {
    "name": "Dear Diary",
    "slug": "dear-diary",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "deardiary",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sahil143.deardiary"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.sahil143.deardiary",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": "Dear Diary needs your microphone to capture voice memories."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Dear Diary needs photo access to save image memories.",
          "cameraPermission": "Dear Diary needs camera access to capture photos and videos."
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "speechmaticsApiKey": "",
      "speechmaticsRegion": "eu",
      "cogneeApiUrl": "",
      "cogneeApiKey": "",
      "llmApiKey": "",
      "eas": {
        "projectId": "dba537ff-5ed3-4dc8-88b5-ca527b6ee62b"
      }
    },
    "owner": "sahil_bhai"
  }
}
