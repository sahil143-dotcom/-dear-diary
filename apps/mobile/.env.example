# Environment — copy to .env before building

# Speechmatics (voice transcription) — REQUIRED for live STT
# Get key: https://portal.speechmatics.com/
EXPO_PUBLIC_SPEECHMATICS_API_KEY=
EXPO_PUBLIC_SPEECHMATICS_REGION=eu

# Cognee Cloud (optional — app works offline with local graph)
# Sign up: https://www.cognee.ai/ — code COGNEE-35 for hackathon
EXPO_PUBLIC_COGNEE_API_URL=https://api.cognee.ai
EXPO_PUBLIC_COGNEE_API_KEY=
